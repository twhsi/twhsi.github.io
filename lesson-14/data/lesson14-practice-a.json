{
  "grammar": [
    {
      "id": "grammar-te-kudasai",
      "pattern": "Vてください",
      "meaning": "請求",
      "explanation": "先把動詞換成て形，再接 ください，表示請對方做某動作。",
      "examples": [
        {
          "jp": "問題を読んでください。",
          "zh": "請讀題目。"
        },
        {
          "jp": "電話番号を教えてください。",
          "zh": "請告訴我電話號碼。"
        }
      ]
    },
    {
      "id": "grammar-mashouka",
      "pattern": "V2 + ましょうか",
      "meaning": "提案",
      "explanation": "主動提議幫忙或釋出善意，語氣接近「要不要我來......？」。",
      "examples": [
        {
          "jp": "手伝いましょうか。",
          "zh": "要不要我幫忙？"
        },
        {
          "jp": "窓を閉めましょうか。",
          "zh": "要不要我來關窗？"
        }
      ]
    },
    {
      "id": "grammar-teimasu",
      "pattern": "Vています",
      "meaning": "進行／持續",
      "explanation": "可表示正在進行、習慣持續，或某個狀態維持著。",
      "examples": [
        {
          "jp": "ミラーさんは今レポートを読んでいます。",
          "zh": "米勒先生現在正在看報告。"
        },
        {
          "jp": "私は日本語を勉強しています。",
          "zh": "我一直在學日文。"
        }
      ]
    }
  ],
